{
  "index": {
    "number_of_shards": 3,
    "number_of_replicas": 1
  },
  "analysis": {
    "tokenizer": {
      "nori_mixed_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "mixed"
      },
      "edge_ngram_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 10,
        "token_chars": ["letter", "digit"]
      }
    },
    "filter": {
      "nori_pos_filter": {
        "type": "nori_part_of_speech",
        "stoptags": [
          "E", "IC", "J", "MAG", "MAJ", "MM", "SP", "SSC", "SSO", "SC", "SE", "XPN", "XSA", "XSN", "XSV", "UNA", "NA", "VSV"
        ]
      }
    },
    "analyzer": {
      "korean_nori_analyzer": {
        "type": "custom",
        "tokenizer": "nori_mixed_tokenizer",
        "filter": ["lowercase", "nori_pos_filter"]
      },
      "edge_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "edge_ngram_tokenizer",
        "filter": ["lowercase"]
      }
    }
  }
}